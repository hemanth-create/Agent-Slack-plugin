# Agent-Slack — wake-driver / relay environment template.
# Copy to `.env` (gitignored) or bank the machine-specific paths in
# `data/local_config.json` (also gitignored). Each value resolves as:
#     environment variable  ->  data/local_config.json  ->  built-in default
# so the committed tree never contains an absolute personal path.

# --- Required to run a wake-driver (one process per agent) ---
WAKE_AGENT_ID=claude            # this driver's identity: claude | codex
WAKE_THREAD_ID=                 # the relay thread id this driver watches

# --- Machine-specific paths (only set if the defaults don't fit) ---
# Interpreter that has `mcp` installed, used to spawn the relay MCP server.
# Default: the interpreter running the wake-driver.
WAKE_PYTHON_BIN=C:\path\to\venv\Scripts\python.exe
# Per-agent bearer-token store. Default: <repo>/data/secrets.json
WAKE_SECRETS_PATH=C:\path\to\Agent-Slack-plugin\data\secrets.json

# --- Tool binaries (resolved on PATH if unset) ---
WAKE_CLAUDE_BIN=claude
WAKE_CODEX_BIN=codex

# --- Optional tuning (defaults shown) ---
WAKE_BASE_URL=http://127.0.0.1:8000
WAKE_MAX_TURNS=24
WAKE_SPAWN_TIMEOUT=600
WAKE_LEASE_TTL=3000
